# ArgoCD Application — apply to the ARGOCD cluster (namespace argocd).
# {SVC} service, {ENV} dev|test|prod, {PROJECT} dev-daton|test-daton|prod,
# {SERVER} dev-test https://34.72.110.156  | prod https://34.42.255.233,
# {NAMESPACE} dev-saras|test-saras|saras.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {SVC}-{ENV}
  namespace: argocd
spec:
  project: {PROJECT}
  source:
    repoURL: https://github.com/sarasanalytics-com/{SVC}.git
    targetRevision: argo-deployment
    path: helm
    helm:
      valueFiles:
        - {ENV}-values.yaml
  destination:
    server: {SERVER}
    namespace: {NAMESPACE}
  syncPolicy:
    automated:
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
# Auto-sync (above) IS the deploy engine: a commit that changes the image tag in
# {ENV}-values.yaml on argo-deployment is applied automatically. To apply it
# immediately instead of waiting for the next poll, nudge a hard refresh:
#   kubectl --context {argocd} annotate application {SVC}-{ENV} -n argocd \
#     argocd.argoproj.io/refresh=hard --overwrite
# (No Kargo stage/authorized-stage annotation — promotion is direct; see
#  references/promotion.md.)
