# Kargo wiring — apply to the ARGOCD cluster. {SVC} = service/project name.
# Prereqs (see gotchas.md): create the Project namespace's kargo-git-creds &
# kargo-ar-creds, add the kargo-controller-read-secrets RoleBinding, and restart
# the kargo-controller. Manual promotion is the default (no auto-promotion policy).
---
apiVersion: kargo.akuity.io/v1alpha1
kind: Project
metadata:
  name: {SVC}
---
apiVersion: kargo.akuity.io/v1alpha1
kind: Warehouse
metadata:
  name: {SVC}
  namespace: {SVC}
spec:
  freightCreationPolicy: Automatic
  interval: 5m0s
  subscriptions:
    - image:
        repoURL: us-central1-docker.pkg.dev/daton-210514/{SVC}/{SVC}-dev
        allowTags: "^[0-9]+$"        # numeric github.run_id tags
        discoveryLimit: 20
        imageSelectionStrategy: NewestBuild
        strictSemvers: false
---
# test Stage: subscribes to the Warehouse; promotion writes test-values + syncs the test app.
apiVersion: kargo.akuity.io/v1alpha1
kind: Stage
metadata:
  name: test
  namespace: {SVC}
spec:
  requestedFreight:
    - origin: { kind: Warehouse, name: {SVC} }
      sources: { direct: true }
  promotionTemplate:
    spec:
      vars:
        - { name: imageRepo, value: us-central1-docker.pkg.dev/daton-210514/{SVC}/{SVC}-dev }
        - { name: gitRepo, value: https://github.com/sarasanalytics-com/{SVC}.git }
      steps:
        - uses: git-clone
          config: { repoURL: "${{ vars.gitRepo }}", checkout: [ { branch: argo-deployment, path: ./src } ] }
        - uses: yaml-update
          config: { path: ./src/helm/test-values.yaml, updates: [ { key: image.tag, value: "${{ imageFrom(vars.imageRepo).Tag }}" } ] }
        - as: commit
          uses: git-commit
          config: { path: ./src, message: "chore(test): promote {SVC} to ${{ imageFrom(vars.imageRepo).Tag }}" }
        - uses: git-push
          config: { path: ./src }
        - uses: argocd-update
          config: { apps: [ { name: {SVC}-test, namespace: argocd, sources: [ { repoURL: "${{ vars.gitRepo }}", desiredRevision: "${{ outputs.commit.commit }}" } ] } ] }
---
# prod Stage: sources from the test Stage (enforces dev→test→prod). Same steps, prod-values + prod app.
apiVersion: kargo.akuity.io/v1alpha1
kind: Stage
metadata:
  name: prod
  namespace: {SVC}
spec:
  requestedFreight:
    - origin: { kind: Warehouse, name: {SVC} }
      sources: { stages: [ test ] }
  promotionTemplate:
    spec:
      vars:
        - { name: imageRepo, value: us-central1-docker.pkg.dev/daton-210514/{SVC}/{SVC}-dev }
        - { name: gitRepo, value: https://github.com/sarasanalytics-com/{SVC}.git }
      steps:
        - uses: git-clone
          config: { repoURL: "${{ vars.gitRepo }}", checkout: [ { branch: argo-deployment, path: ./src } ] }
        - uses: yaml-update
          config: { path: ./src/helm/prod-values.yaml, updates: [ { key: image.tag, value: "${{ imageFrom(vars.imageRepo).Tag }}" } ] }
        - as: commit
          uses: git-commit
          config: { path: ./src, message: "chore(prod): promote {SVC} to ${{ imageFrom(vars.imageRepo).Tag }}" }
        - uses: git-push
          config: { path: ./src }
        - uses: argocd-update
          config: { apps: [ { name: {SVC}-prod, namespace: argocd, sources: [ { repoURL: "${{ vars.gitRepo }}", desiredRevision: "${{ outputs.commit.commit }}" } ] } ] }
